generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model category {
  category_id Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(50)
  product     product[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model product {
  product_id  Int           @id @default(autoincrement())
  name        String        @db.VarChar(50)
  description String?
  price       Decimal       @db.Decimal(10, 2)
  stock       Int           @default(0)
  active      Boolean?      @default(true)
  category_id Int?
  category    category?     @relation(fields: [category_id], references: [category_id])
  sale_detail sale_detail[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sale {
  sale_id     Int           @id @default(autoincrement())
  sale_date   DateTime      @default(dbgenerated("CURRENT_DATE")) @db.Date
  total       Decimal?      @default(0) @db.Decimal(10, 2)
  created_at  DateTime?     @default(now()) @db.Timestamp(6)
  sale_detail sale_detail[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sale_detail {
  detail_id  Int     @id @default(autoincrement())
  sale_id    Int
  product_id Int
  quantity   Int
  unit_price Decimal @db.Decimal(10, 2)
  product    product @relation(fields: [product_id], references: [product_id], onUpdate: NoAction)
  sale       sale    @relation(fields: [sale_id], references: [sale_id], onDelete: Cascade, onUpdate: NoAction)
}
